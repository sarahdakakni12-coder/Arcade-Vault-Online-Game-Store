function setHero(i) {
  heroIndex = (i + RECOMMENDED.length) % RECOMMENDED.length;
  const g = RECOMMENDED[heroIndex];

  $("#heroImg").src = g.image;
  $("#heroTitle").textContent = g.title;
  $("#heroDesc").textContent = g.description;
  $("#heroMeta").textContent = `${g.category} • ${g.platform} • ★ ${g.rating} • ${money(g.price)}`;

  $("#heroDetailsBtn").dataset.detail = g.id;
  $("#heroAddCartBtn").dataset.addcart = g.id;
}

function startHeroAuto() {
  stopHeroAuto();
  heroTimer = setInterval(() => setHero(heroIndex + 1), 4500);
}

function stopHeroAuto() {
  if (heroTimer) clearInterval(heroTimer);
  heroTimer = null;
}

