function getFilteredSortedGames() {
  const search = $("#searchInput").value.trim().toLowerCase();
  const cat = $("#categoryFilter").value;
  const plat = $("#platformFilter").value;
  const maxPriceRaw = $("#maxPriceFilter").value.trim();
  const maxPrice = maxPriceRaw === "" ? null : Number(maxPriceRaw);
  const sort = $("#sortSelect").value;

  let list = [...GAMES];

  if (search) list = list.filter(g => g.title.toLowerCase().includes(search));
  if (cat !== "all") list = list.filter(g => g.category === cat);
  if (plat !== "all") list = list.filter(g => g.platform === plat);
  if (maxPrice !== null && Number.isFinite(maxPrice)) list = list.filter(g => g.price <= maxPrice);

  if (sort === "name-asc") list.sort((a,b) => a.title.localeCompare(b.title));
  if (sort === "price-asc") list.sort((a,b) => a.price - b.price);
  if (sort === "price-desc") list.sort((a,b) => b.price - a.price);
  if (sort === "rating-desc") list.sort((a,b) => b.rating - a.rating);

  return list;
}

$("#toggleViewBtn").addEventListener("click", () => {
  viewMode = viewMode === "grid" ? "list" : "grid";
  renderGames(getFilteredSortedGames());
});

