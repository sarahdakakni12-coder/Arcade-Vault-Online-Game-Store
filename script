  $("#categoryFilter").value = "all";
  $("#platformFilter").value = "all";
  $("#maxPriceFilter").value = "";
  $("#sortSelect").value = "name-asc";
  renderGames(getFilteredSortedGames());
});

function initFilters() {
  const catSel = $("#categoryFilter");
  const platSel = $("#platformFilter");

  uniqueValues("category").forEach(v => {
    const opt = document.createElement("option");
    opt.value = v;
    opt.textContent = v;
    catSel.appendChild(opt);
  });

  uniqueValues("platform").forEach(v => {
    const opt = document.createElement("option");
    opt.value = v;
    opt.textContent = v;
    platSel.appendChild(opt);
  });
}

