/* =========================
  CART
========================= */
function calcCartTotals() {
  let subtotal = 0;
  for (const [id, qty] of Object.entries(cart)) {
    const g = getGame(id);
    if (g) subtotal += g.price * qty;
  }
  const tax = subtotal * 0.13;
  const total = subtotal + tax;
  return { subtotal, tax, total };
}

function renderCart() {
  const list = $("#cartList");
  const summary = $("#cartSummary");
  const entries = Object.entries(cart);

  if (entries.length === 0) {
    list.innerHTML = `<p class="muted">Your cart is empty.</p>`;
    summary.innerHTML = "";
    return;
  }

  list.innerHTML = entries.map(([id, qty]) => {
    const g = getGame(id);
    if (!g) return "";
    return `
      <div class="lineItem">
        <img src="${g.image}" alt="${g.title}">
        <div>
          <div class="lineTitle">${g.title}</div>
          <div class="muted">${g.category} • ${g.platform}</div>
          <div class="muted">${money(g.price)} each</div>

          <div class="row spacedTopSmall">
            <button class="ghost" data-dec="${g.id}" type="button">-</button>
            <div class="qtyBox">${qty}</div>
            <button class="ghost" data-inc="${g.id}" type="button">+</button>
            <button class="ghost" data-remove="${g.id}" type="button">Remove</button>
          </div>
        </div>
      </div>
    `;
  }).join("");

  const { subtotal, tax, total } = calcCartTotals();
  summary.innerHTML = `
    <div class="totals__row"><span>Subtotal</span><span>${money(subtotal)}</span></div>
    <div class="totals__row"><span>Tax (13%)</span><span>${money(tax)}</span></div>
    <div class="totals__row totals__row--big"><span>Total</span><span>${money(total)}</span></div>
  `;
}

