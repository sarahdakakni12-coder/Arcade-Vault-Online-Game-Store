/* =========================
  STORAGE
========================= */
const LS_CART = "av_cart_v2";         // { [id]: qty }
const LS_WISHLIST = "av_wishlist_v1"; // [id]
const LS_ORDER = "av_last_order_v1";  // order object

function loadJSON(key, fallback) {
  try {
    const raw = localStorage.getItem(key);
    if (!raw) return fallback;
    return JSON.parse(raw);
  } catch {
    return fallback;
  }
}
function saveJSON(key, val) {
  localStorage.setItem(key, JSON.stringify(val));
}

let cart = loadJSON(LS_CART, {});
let wishlist = loadJSON(LS_WISHLIST, []);
let selectedGameId = null;

/* =========================
  HELPERS
========================= */
const $ = (sel) => document.querySelector(sel);
function money(n) { return `$${Number(n).toFixed(2)}`; }
function cartCount() { return Object.values(cart).reduce((s, q) => s + q, 0); }

function updateBadges() {
  $("#cartBadge").textContent = String(cartCount());
  $("#wishlistBadge").textContent = String(wishlist.length);
}

function addToCart(gameId, qty = 1) {
  cart[gameId] = (cart[gameId] || 0) + qty;
  if (cart[gameId] <= 0) delete cart[gameId];
  saveJSON(LS_CART, cart);
  updateBadges();
}

function removeFromCart(gameId) {
  delete cart[gameId];
  saveJSON(LS_CART, cart);
  updateBadges();
}

function addToWishlist(gameId) {
  if (!wishlist.includes(gameId)) wishlist.push(gameId);
  saveJSON(LS_WISHLIST, wishlist);
  updateBadges();
}

function removeFromWishlist(gameId) {
  wishlist = wishlist.filter(id => id !== gameId);
  saveJSON(LS_WISHLIST, wishlist);
  updateBadges();
}

function getGame(id) { return GAMES.find(g => g.id === id) || null; }
function uniqueValues(key) { return Array.from(new Set(GAMES.map(g => g[key]))).sort(); }

/* =========================
  PAGE SWITCHING
========================= */
function showPage(name) {
  // Stop the hero interval when leaving home
  if (name !== "home") stopHeroAuto();

  const pages = ["home","games","detail","about","wishlist","cart","checkout","receipt"];
  for (const p of pages) {
    const el = document.getElementById(`page-${p}`);
    if (!el) continue;
    el.classList.toggle("hidden", p !== name);
  }

  window.scrollTo(0, 0);

  if (name === "home") renderHome();
  if (name === "games") renderGames(getFilteredSortedGames()); // ALL games (not recommended)
  if (name === "detail") renderDetail();
  if (name === "cart") renderCart();
  if (name === "wishlist") renderWishlist();
  if (name === "checkout") renderCheckoutSummary();
  if (name === "receipt") renderReceipt();
}

/* =========================
  NAVIGATION + GLOBAL CLICK HANDLER
========================= */
document.addEventListener("click", (e) => {
  const nav = e.target.closest("[data-page]");
  if (nav) {
    showPage(nav.getAttribute("data-page"));
    return;
  }

  const view = e.target.closest("[data-view]");
  if (view) {
    selectedGameId = view.getAttribute("data-view");
    showPage("detail");
    return;
  }

  const addc = e.target.closest("[data-addcart]");
  if (addc) {
    addToCart(addc.getAttribute("data-addcart"), 1);
    return;
  }

  const addw = e.target.closest("[data-addwish]");
  if (addw) {
    addToWishlist(addw.getAttribute("data-addwish"));
    return;
  }

  const inc = e.target.closest("[data-inc]");
  if (inc) {
    addToCart(inc.getAttribute("data-inc"), 1);
    renderCart();
    return;
  }

  const dec = e.target.closest("[data-dec]");
  if (dec) {
    addToCart(dec.getAttribute("data-dec"), -1);
    renderCart();
    return;
  }

  const rm = e.target.closest("[data-remove]");
  if (rm) {
    removeFromCart(rm.getAttribute("data-remove"));
    renderCart();
    return;
  }

  const wc = e.target.closest("[data-wishcart]");
  if (wc) {
    addToCart(wc.getAttribute("data-wishcart"), 1);
    return;
  }

  const wr = e.target.closest("[data-wishremove]");
  if (wr) {
    removeFromWishlist(wr.getAttribute("data-wishremove"));
    renderWishlist();
    return;
  }

  const heroDetail = e.target.closest("#heroDetailsBtn");
  if (heroDetail) {
    selectedGameId = $("#heroDetailsBtn").dataset.detail;
    showPage("detail");
    return;
  }

  const heroAdd = e.target.closest("#heroAddCartBtn");
  if (heroAdd) {
    addToCart($("#heroAddCartBtn").dataset.addcart, 1);
    return;
  }
});

