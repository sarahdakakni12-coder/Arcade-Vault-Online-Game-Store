function renderCheckoutSummary() {
  const box = $("#checkoutSummary");
  const entries = Object.entries(cart);

  if (entries.length === 0) {
    box.innerHTML = `<p class="muted">Cart is empty.</p>`;
    return;
  }

  let lines = "";
  for (const [id, qty] of entries) {
    const g = getGame(id);
    if (!g) continue;
    lines += `
      <div class="checkoutRow">
        <span class="muted">${g.title} × ${qty}</span>
        <span class="muted">${money(g.price * qty)}</span>
      </div>
    `;
  }

  const { subtotal, tax, total } = calcCartTotals();

  box.innerHTML = `
    ${lines}
    <hr class="divider">
    <div class="checkoutRow"><span class="muted">Subtotal</span><span class="muted">${money(subtotal)}</span></div>
    <div class="checkoutRow"><span class="muted">Tax (13%)</span><span class="muted">${money(tax)}</span></div>
    <div class="checkoutRow checkoutRow--total"><span>Total</span><span>${money(total)}</span></div>
  `;
}

function digitsOnly(s) { return (s || "").replace(/\D/g, ""); }
function isValidExpiry(mmYY) { return /^(0[1-9]|1[0-2])\/\d{2}$/.test((mmYY || "").trim()); }

$("#payBtn").addEventListener("click", async () => {
  $("#checkoutError").textContent = "";

  const email = $("#checkoutEmail").value.trim();
  const name = $("#cardName").value.trim();
  const cardNum = digitsOnly($("#cardNumber").value);
  const exp = $("#cardExpiry").value.trim();
  const cvv = digitsOnly($("#cardCvv").value);

  if (!isValidEmail(email)) { $("#checkoutError").textContent = "Enter a valid email."; return; }
  if (!name) { $("#checkoutError").textContent = "Name on card is required."; return; }
  if (!/^\d{16}$/.test(cardNum)) { $("#checkoutError").textContent = "Card number must be exactly 16 digits."; return; }
  if (!isValidExpiry(exp)) { $("#checkoutError").textContent = "Expiry must be MM/YY."; return; }
  if (!/^\d{3,4}$/.test(cvv)) { $("#checkoutError").textContent = "CVV must be 3 or 4 digits."; return; }
  if (cartCount() === 0) { $("#checkoutError").textContent = "Your cart is empty."; return; }

  const overlay = $("#processingOverlay");
  overlay.classList.remove("hidden");
  overlay.setAttribute("aria-hidden", "false");

  await new Promise(res => setTimeout(res, 1400));

  const now = new Date();
  const y = now.getFullYear();
  const m = String(now.getMonth()+1).padStart(2,"0");
  const d = String(now.getDate()).padStart(2,"0");
  const orderDateYMD = `${y}${m}${d}`;
  const orderDateDMY = `${d}/${m}/${y}`;
  const rand4 = String(Math.floor(1000 + Math.random()*9000));
  const orderNumber = `ORD-${orderDateYMD}-${rand4}`;

  const items = Object.entries(cart).map(([id, qty]) => {
    const g = getGame(id);
    return { id, title: g ? g.title : id, price: g ? g.price : 0, qty };
  });

  const totals = calcCartTotals();

  const order = {
    orderNumber,
    orderDate: orderDateDMY,
    email,
    items,
    subtotal: totals.subtotal,
    tax: totals.tax,
    total: totals.total
  };

  saveJSON(LS_ORDER, order);

  cart = {};
  saveJSON(LS_CART, cart);
  updateBadges();

  overlay.classList.add("hidden");
  overlay.setAttribute("aria-hidden", "true");

  showPage("receipt");
});

/* =========================
  RECEIPT + PRINT
========================= */
function renderReceipt() {
  const order = loadJSON(LS_ORDER, null);
  const box = $("#receiptBox");

  if (!order) {
    box.innerHTML = `<p class="muted">No receipt found.</p>`;
    return;
  }

  const rows = order.items.map(it => `
    <tr>
      <td>${it.title}</td>
      <td>${it.qty}</td>
      <td>${money(it.price)}</td>
      <td>${money(it.price * it.qty)}</td>
    </tr>
  `).join("");

  box.innerHTML = `
    <h2>Order Confirmation</h2>
    <div class="muted">Order Number: <strong>${order.orderNumber}</strong></div>
    <div class="muted">Order Date: <strong>${order.orderDate}</strong></div>
    <div class="muted">Email: <strong>${order.email}</strong></div>

    <table class="receiptTable">
      <thead>
        <tr>
          <th>Item</th>
          <th>Qty</th>
          <th>Price</th>
          <th>Line Total</th>
        </tr>
      </thead>
      <tbody>${rows}</tbody>
    </table>

    <div class="totals receiptTotals">
      <div class="totals__row"><span>Subtotal</span><span>${money(order.subtotal)}</span></div>
      <div class="totals__row"><span>Tax (13%)</span><span>${money(order.tax)}</span></div>
      <div class="totals__row totals__row--big"><span>Total</span><span>${money(order.total)}</span></div>
    </div>
  `;
}

